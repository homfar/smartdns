DB_PATH=/data/app.db
MMDB_PATH=/mmdb/GeoLite2-Country.mmdb
HTTP_ADDR=:5555
DNS_ADDR=:53
NO_SYNC=true
PEER_URL=http://peer:5555
SYNC_TOKEN=change-me
SYNC_ALLOWLIST=peer,127.0.0.1
NODE_ID=node-1
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-me-long-random
SYNC_INTERVAL_SEC=30
TTL_MIN=30
TTL_MAX=86400
# Optional: override Docker base images when Docker Hub is blocked.
# Examples:
# GO_IMAGE=registry.example.com/library/golang:1.22
# RUNTIME_IMAGE=registry.example.com/library/alpine:3.20
GO_IMAGE=golang:1.22
RUNTIME_IMAGE=alpine:3.20
